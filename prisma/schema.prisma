generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("user")
  timezone     String   @default("Australia/Brisbane")
  createdAt    DateTime @default(now())

  assignments       Assignment[]
  habits            Habit[]
  habitLogs         HabitLog[]
  pomodoroSessions  PomodoroSession[]
  diaryEntries      DiaryEntry[]
  goals             Goal[]
  weeklyCommitments WeeklyCommitment[]
  timePlanSlots     TimePlanSlot[]
  settings          UserSettings?
  moodCheckIns      MoodCheckIn[]
  exams             Exam[]
  xpEvents          XpEvent[]
  studyStreak       StudyStreak?
  calendarSyncs     CalendarSync[]
}

model Assignment {
  id                String    @id @default(uuid())
  userId            String
  title             String
  description       String    @default("")
  dueDate           DateTime
  status            String    @default("pending")
  progress          Int       @default(0)
  startedAt         DateTime?
  emailEnabled      Boolean   @default(false)
  reminderEmail     String?
  ccEmails          String?
  reminderSchedule  String    @default("[]")
  referenceCode     String    @unique @default("")
  recurType         String?
  recurEndDate      DateTime?
  recurParentId     String?
  isImportant       Boolean   @default(false)
  estimatedPomodoros Int      @default(1)
  category          String    @default("School")
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pomodoroSessions PomodoroSession[]
  reminderLogs     ReminderLog[]
  subtasks         Subtask[]
  timePlanSlots    TimePlanSlot[]

  @@index([userId, dueDate])
}

model Subtask {
  id           String   @id @default(uuid())
  assignmentId String
  title        String
  completed    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, sortOrder])
}

model ReminderLog {
  id           String   @id @default(uuid())
  assignmentId String
  reminderType String
  sentAt       DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, reminderType])
}

model Habit {
  id        String   @id @default(uuid())
  userId    String
  title     String
  frequency String   @default("daily")
  createdAt DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]
}

model HabitLog {
  id        String  @id @default(uuid())
  habitId   String
  userId    String
  logDate   String
  completed Boolean @default(true)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, logDate])
}

model PomodoroSession {
  id              String   @id @default(uuid())
  userId          String
  assignmentId    String?
  startTime       DateTime @default(now())
  durationMinutes Int
  type            String   @default("work")
  createdAt       DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
}

model DiaryEntry {
  id        String   @id @default(uuid())
  userId    String
  entryDate String
  content   String
  moodScore Int?
  weather   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
}

model Goal {
  id        String   @id @default(uuid())
  userId    String
  title     String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyCommitment {
  id        String   @id @default(uuid())
  userId    String
  title     String
  dayOfWeek Int
  startHour Int
  startMin  Int
  endHour   Int      @default(0)
  endMin    Int      @default(30)
  duration  Int      @default(30)
  color     String   @default("#9ca3af")
  termStart String?
  termEnd   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CalendarSync {
  id           String   @id @default(uuid())
  userId       String
  provider     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  calendarId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model TimePlanSlot {
  id           String   @id @default(uuid())
  userId       String
  assignmentId String
  weekStart    String
  dayOfWeek    Int
  startHour    Int
  startMin     Int
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
}

model UserSettings {
  id               String   @id @default(uuid())
  userId           String   @unique
  urgentCutoffDays Int      @default(7)
  categoryColors   String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MoodCheckIn {
  id        String   @id @default(uuid())
  userId    String
  date      String
  mood      Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Exam {
  id        String   @id @default(uuid())
  userId    String
  title     String
  subject   String
  examDate  String
  difficulty Int     @default(3)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model XpEvent {
  id        String   @id @default(uuid())
  userId    String
  source    String
  points    Int
  date      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model StudyStreak {
  id            String   @id @default(uuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveDate String  @default("")
  freezesAvailable Int   @default(0)
  freezesUsed   Int      @default(0)
  updatedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
